{
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "lefthook": "^1.13.1",
    "rollup": "^4.60.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "ts-jest": "^29.4.3",
    "typescript": "^5.9.2",
    "userscript-metadata": "^1.1.0"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript --bundleConfigAsCjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "predev": "npm run clean",
    "ci": "biome ci --error-on-warnings && npm run lint:structure",
    "dev": "rollup --config rollup.config.ts --configPlugin typescript --bundleConfigAsCjs --watch",
    "format": "biome check --write --error-on-warnings",
    "lint:structure": "node scripts/check_project_structure.cjs",
    "test": "jest --passWithNoTests",
    "release": "git tag $(date '+%Y%m%d') && git push --tags"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
